# Copy this file to ".env" (same folder) and fill in your values.
# The server loads it automatically on start.

# Admin panel password
ADMIN_PASSWORD=saree-admin

# Paytm Payment Gateway — get credentials from https://business.paytm.com
#   Dashboard → Developer → API Keys
# Use TEST credentials while developing; switch to LIVE to go live.
# Leave these blank to run checkout in demo mode (no real charge).
PAYTM_MID=
PAYTM_MERCHANT_KEY=
# WEBSTAGING for test environment, DEFAULT for production
PAYTM_WEBSITE=WEBSTAGING

# Order confirmation email (SMTP). Leave blank to run in demo mode (email is
# logged to the console instead of sent).
# Gmail example: create an "App Password" (Google Account → Security →
#   2-Step Verification → App passwords) and use it as SMTP_PASS.
#   SMTP_HOST=smtp.gmail.com   SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# "From" address shown on the email (defaults to SMTP_USER)
SHOP_EMAIL=
